<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MoneyPattern™ Profile — A Rise Growth Partners Initiative</title>
<meta name="description" content="Understand the behavioural patterns that shape how you save, invest, and plan. A research-backed assessment from Rise Growth Partners." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,500;1,9..144,600&display=swap" rel="stylesheet" />
<style>
  :root {
    /* Palette: F3DECA cream · FA9483 coral · 2D4057 navy · 4097AA teal */
    --rise-cream: #F3DECA;          /* base background — warm cream */
    --rise-cream-warm: #E7CFB8;     /* slightly deeper cream */
    --rise-cream-deep: #DABEA2;     /* deepest cream */
    --rise-paper: #FAE8D7;          /* lightest paper for cards */
    --rise-black: #2D4057;          /* deep navy — primary dark */
    --rise-charcoal: #3A5068;       /* lighter navy variant */
    --rise-graphite: #243549;       /* deeper navy */
    --rise-ink: #1A2737;            /* deepest navy */
    --rise-red: #FA9483;            /* coral — primary accent */
    --rise-red-deep: #E87766;       /* darker coral for hover states */
    --rise-red-soft: rgba(250, 148, 131, 0.12);
    --rise-teal: #4097AA;           /* teal — secondary accent */
    --rise-teal-deep: #2E7D90;
    --rise-text: #2D4057;           /* navy text on cream */
    --rise-text-muted: #6B7C8E;     /* muted navy for body copy */
    --rise-text-light: #F3DECA;     /* cream text on dark sections */
    --rise-text-light-muted: #A0B0BF;
    --rise-line: rgba(45, 64, 87, 0.15);
    --rise-line-light: rgba(243, 222, 202, 0.14);
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.5rem;
    --space-6: 2rem;
    --space-7: 3rem;
    --space-8: 4rem;
    --space-9: 6rem;
    --space-10: 8rem;
    --container: 1280px;
    --container-tight: 1080px;
    --ease: cubic-bezier(0.22, 1, 0.36, 1);
    --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  body {
    font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
    background: var(--rise-cream);
    color: var(--rise-text);
    line-height: 1.55;
    font-weight: 400;
    overflow-x: hidden;
  }

  ::selection { background: var(--rise-red); color: white; }

  /* ─────────── Typography ─────────── */
  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rise-red);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--rise-red);
  }
  .eyebrow.center::before { display: none; }
  .eyebrow.center::after { display: none; }
  .eyebrow.center {
    justify-content: center;
  }

  .display {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.035em;
    color: var(--rise-black);
  }
  .display .accent { color: var(--rise-red); font-style: italic; font-weight: 700; }
  .display .light { font-weight: 200; font-style: italic; opacity: 0.6; }

  h1.display { font-size: clamp(2.6rem, 6.8vw, 5.6rem); }
  h2.display { font-size: clamp(2rem, 4.8vw, 3.8rem); }
  h3.display { font-size: clamp(1.4rem, 2.4vw, 2rem); letter-spacing: -0.02em; }

  .lead {
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.55;
    color: var(--rise-text-muted);
    font-weight: 400;
    max-width: 56ch;
  }

  /* ─────────── Layout ─────────── */
  .container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
  }
  .container-tight {
    max-width: var(--container-tight);
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
  }
  section { padding: clamp(4rem, 9vw, 9rem) 0; position: relative; }
  .dark { background: var(--rise-black); color: var(--rise-text-light); }
  .dark .display { color: white; }
  .dark .lead { color: var(--rise-text-light-muted); }
  .dark .eyebrow { color: var(--rise-red); }

  /* ─────────── Navigation ─────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--rise-line);
    transition: padding 0.3s var(--ease);
  }
  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 1.1rem clamp(1.25rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-mark {
    height: 32px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }
  @media (max-width: 540px) {
    .logo-mark { height: 26px; }
  }
  .nav-links {
    display: flex;
    gap: 2.2rem;
    list-style: none;
    align-items: center;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--rise-text);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    position: relative;
    padding: 0.4rem 0;
    transition: color 0.2s var(--ease);
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 2.5px;
    background: var(--rise-red-deep);
    border-radius: 2px;
    transition: width 0.3s var(--ease);
  }
  .nav-links a:hover { color: var(--rise-black); }
  .nav-links a:hover::after { width: 100%; }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.6rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: all 0.25s var(--ease);
    cursor: pointer;
    border: 1.5px solid transparent;
    white-space: nowrap;
  }
  .btn-primary {
    background: var(--rise-red);
    color: var(--rise-black);
    border-color: var(--rise-red);
  }
  .btn-primary:hover {
    background: var(--rise-red-deep);
    border-color: var(--rise-red-deep);
    transform: translateY(-1px);
    box-shadow: 0 12px 28px -10px rgba(250, 148, 131, 0.6);
  }
  .btn-ghost {
    background: transparent;
    color: var(--rise-black);
    border-color: var(--rise-black);
  }
  .btn-ghost:hover {
    background: var(--rise-black);
    color: white;
  }
  .dark .btn-ghost {
    color: white;
    border-color: rgba(255, 255, 255, 0.35);
  }
  .dark .btn-ghost:hover {
    background: white;
    color: var(--rise-black);
    border-color: white;
  }
  .btn-arrow::after {
    content: "→";
    transition: transform 0.25s var(--ease);
  }
  .btn-arrow:hover::after { transform: translateX(3px); }

  .nav-cta { font-size: 0.85rem; padding: 0.75rem 1.3rem; }

  .nav-toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--rise-line);
    width: 42px;
    height: 42px;
    border-radius: 8px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .nav-toggle span {
    width: 18px;
    height: 1.5px;
    background: var(--rise-black);
    position: relative;
  }
  .nav-toggle span::before,
  .nav-toggle span::after {
    content: "";
    position: absolute;
    left: 0;
    width: 18px;
    height: 1.5px;
    background: var(--rise-black);
  }
  .nav-toggle span::before { top: -6px; }
  .nav-toggle span::after { top: 6px; }

  /* ─────────── Hero ─────────── */
  .hero {
    padding: clamp(3rem, 8vw, 7rem) 0 clamp(3rem, 7vw, 6rem);
    position: relative;
    overflow: hidden;
  }

  .hero-inner { position: relative; z-index: 1; }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 3rem;
    align-items: end;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.45fr 1fr;
      gap: 5rem;
    }
  }

  .hero-headline {
    margin-top: 1.5rem;
    margin-bottom: 1.75rem;
  }
  .hero-sub {
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    color: var(--rise-text-muted);
    max-width: 36rem;
    line-height: 1.6;
    margin-bottom: 2.25rem;
  }
  .hero-ctas {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .hero-callout {
    background: #FFFFFF;
    border: 1px solid var(--rise-line);
    border-radius: 18px;
    padding: 1.75rem 1.5rem;
    position: relative;
    box-shadow: 0 30px 60px -30px rgba(0,0,0,0.15);
  }
  .hero-callout::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 1.5rem;
    width: 48px;
    height: 3px;
    background: var(--rise-red);
  }
  .hero-callout-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rise-text-muted);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .archetype-chip {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 0.85rem;
    align-items: center;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rise-line);
    transition: padding 0.2s var(--ease);
  }
  .archetype-chip:last-child { border-bottom: none; }
  .archetype-chip:hover { padding-left: 0.25rem; }
  .archetype-chip-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--rise-cream-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
  }
  .archetype-chip-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--rise-text);
    letter-spacing: -0.005em;
  }

  /* ─────────── Stats Bar ─────────── */
  .stats {
    background: var(--rise-black);
    color: var(--rise-text-light);
    padding: clamp(2.5rem, 5vw, 4rem) 0;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 1.5rem;
  }
  @media (min-width: 768px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .stat {
    padding-left: 1.25rem;
    border-left: 2px solid var(--rise-red);
  }
  .stat-number {
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: white;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--rise-text-light-muted);
    line-height: 1.45;
  }

  /* ─────────── Section Header ─────────── */
  .section-header {
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 52rem;
  }
  .section-header.center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }
  .section-header h2 {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  /* ─────────── Blueprint Section ─────────── */
  .blueprint-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 3.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .blueprint-grid { grid-template-columns: 1fr 1.05fr; gap: 5rem; }
  }
  .blueprint-list {
    margin-top: 2rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .blueprint-list li {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 1rem;
    align-items: start;
    font-size: 1.025rem;
    color: var(--rise-text);
    line-height: 1.5;
  }
  .blueprint-list .tick {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--rise-red);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .blueprint-list .tick svg { width: 14px; height: 14px; }

  /* ─────────── Profile Card ─────────── */
  .profile-card {
    background: #FFFFFF;
    border-radius: 24px;
    padding: 2rem;
    box-shadow:
      0 1px 0 rgba(0,0,0,0.04),
      0 30px 70px -30px rgba(0,0,0,0.2);
    border: 1px solid var(--rise-line);
    position: relative;
  }
  .profile-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--rise-line);
    margin-bottom: 1.5rem;
  }
  .profile-card-brand {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rise-text-muted);
  }
  .profile-card-badge {
    background: var(--rise-red-soft);
    color: var(--rise-red);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
  }
  .profile-archetype {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.6rem, 2.4vw, 2rem);
    font-weight: 700;
    color: var(--rise-black);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin-bottom: 0.75rem;
  }
  .profile-archetype span { color: var(--rise-red); font-style: italic; font-weight: 600; }
  .profile-tagline {
    font-size: 0.95rem;
    color: var(--rise-text-muted);
    margin-bottom: 0.4rem;
  }
  .profile-meta {
    font-size: 0.8rem;
    color: var(--rise-text-muted);
    margin-bottom: 1.5rem;
  }
  .profile-section-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rise-red);
    margin-bottom: 0.75rem;
  }
  .profile-pattern-text {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--rise-text);
    margin-bottom: 1.5rem;
  }
  .profile-dimensions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 1rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--rise-line);
  }
  .dim {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.55rem 0;
    font-size: 0.85rem;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }
  .dim-label { color: var(--rise-text-muted); }
  .dim-value { font-weight: 700; color: var(--rise-black); letter-spacing: -0.01em; }

  /* ─────────── About Section ─────────── */
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 3.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr 1.25fr;
      gap: 5rem;
    }
  }

  .about-portrait {
    position: relative;
    width: 100%;
    max-width: 380px;
    margin: 0 auto;
    aspect-ratio: 1 / 1;
  }
  .about-portrait::before {
    content: "";
    position: absolute;
    inset: -1.75rem;
    background: radial-gradient(closest-side, rgba(250, 148, 131, 0.22), transparent 72%);
    z-index: -1;
    border-radius: 50%;
    pointer-events: none;
  }
  .about-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border-radius: 50%;
    display: block;
    box-shadow:
      0 1px 0 rgba(0,0,0,0.04),
      0 30px 70px -30px rgba(45, 64, 87, 0.35);
  }

  .about-name {
    margin-top: 1.25rem;
  }
  .about-paragraphs {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about-paragraphs .lead { max-width: 60ch; }

  /* ─────────── Lenses (Two Lenses Section) ─────────── */
  .lens-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 3.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .lens-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 5rem;
    }
    .lens-grid.reverse {
      grid-template-columns: 1.1fr 1fr;
    }
    .lens-grid.reverse .lens-content { order: 2; }
    .lens-grid.reverse .lens-image { order: 1; }
  }

  .lens-number {
    display: inline-flex;
    align-items: baseline;
    gap: 0.65rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rise-text-muted);
    margin-bottom: 1.5rem;
  }
  .lens-number .num {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-weight: 500;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    color: var(--rise-red);
    text-transform: none;
    line-height: 1;
  }
  .lens-number .dash {
    width: 22px;
    height: 1px;
    background: var(--rise-text-muted);
    opacity: 0.5;
    align-self: center;
  }

  .lens-lead {
    margin-top: 1.5rem;
  }

  .lens-list {
    margin-top: 2.25rem;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem 1rem;
  }
  .lens-list li {
    position: relative;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--rise-line);
    border-left: 3px solid var(--rise-red);
    border-radius: 8px;
    padding: 0.85rem 1rem 0.85rem 1.05rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--rise-black);
    letter-spacing: -0.005em;
    transition: transform 0.25s var(--ease), background 0.25s var(--ease);
  }
  .lens-list li:hover {
    transform: translateX(2px);
    background: rgba(255, 255, 255, 0.85);
  }
  @media (max-width: 540px) {
    .lens-list { grid-template-columns: 1fr; }
  }

  .lens-image {
    position: relative;
  }
  .lens-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 20px;
    box-shadow:
      0 1px 0 rgba(0,0,0,0.04),
      0 30px 70px -30px rgba(0,0,0,0.22);
    transition: transform 0.5s var(--ease);
  }
  .lens-image::before {
    content: "";
    position: absolute;
    inset: -1.5rem;
    background: radial-gradient(closest-side, rgba(250, 148, 131, 0.10), transparent 70%);
    z-index: -1;
    border-radius: 50%;
    pointer-events: none;
  }
  .lens-image:hover img {
    transform: translateY(-4px);
  }

  /* ─────────── Archetypes Grid ─────────── */
  .archetypes-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .archetypes-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .archetypes-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .archetype-card {
    background: var(--rise-graphite);
    border: 1px solid var(--rise-line-light);
    border-radius: 18px;
    padding: 2rem 1.75rem;
    transition: all 0.35s var(--ease);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 280px;
  }
  .archetype-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 3px;
    background: var(--rise-red);
    transition: width 0.5s var(--ease);
  }
  .archetype-card:hover {
    transform: translateY(-4px);
    border-color: rgba(250, 148, 131, 0.5);
    background: #243549;
  }
  .archetype-card:hover::before { width: 100%; }
  .archetype-num {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--rise-text-light-muted);
    margin-bottom: 1.5rem;
  }
  .archetype-icon-box {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: rgba(250, 148, 131, 0.16);
